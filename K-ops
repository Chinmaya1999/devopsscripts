Launch Amazon Linux 2023 , t3.micro

Attach a IAM ROLE TE=EC2, Permisions = admin

vi .bashrc
export PATH=$PATH:/usr/local/bin/

source .bashrc

ssh-keygen

cp /root/.ssh/id_rsa.pub my-keypair.pub

chmod 777 my-keypair.pub



vi kops.sh

#!/bin/bash

set -e

echo "Installing kubectl..."

curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"

chmod +x kubectl
sudo mv kubectl /usr/local/bin/

echo "Installing kops..."

wget https://github.com/kubernetes/kops/releases/download/v1.34.1/kops-linux-amd64

chmod +x kops-linux-amd64
sudo mv kops-linux-amd64 /usr/local/bin/kops

echo "Creating S3 bucket for kops state..."

aws s3api create-bucket \
--bucket chinmaya-kops-testbkt9937.k8s.local \
--region ap-south-1 \
--create-bucket-configuration LocationConstraint=ap-south-1

aws s3api put-bucket-versioning \
--bucket chinmaya-kops-testbkt9937.k8s.local \
--versioning-configuration Status=Enabled

export KOPS_STATE_STORE=s3://chinmaya-kops-testbkt9937.k8s.local

echo "Creating Kubernetes cluster..."

kops create cluster \
--name=chinmaya.k8s.local \
--cloud=aws \
--zones=ap-south-1a,ap-south-1b \
--control-plane-count=1 \
--control-plane-size=t3.small \
--node-count=2 \
--node-size=t3.small \
--node-volume-size=20 \
--control-plane-volume-size=20 \
--ssh-public-key=my-keypair.pub \
--networking=calico

echo "Deploying cluster..."

kops update cluster --name chinmaya.k8s.local --yes --admin

echo "Cluster deployment started..."
echo "Wait 5-10 minutes then run:"

echo "kops validate cluster --wait 10m"
wq!
